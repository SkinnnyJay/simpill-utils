# Image AI Toolkit — environment template
# Copy to .env or .env.local and set values as needed.

# API keys (set the ones you use)
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
XAI_API_KEY=<YOUR_XAI_API_KEY>

# Optional: override default model ids
# GEMINI_API_MODEL=gemini-2.0-flash-exp-image-generation
# OPENAI_API_MODEL=gpt-image-1
# XAI_API_MODEL=grok-2-vision-1212
