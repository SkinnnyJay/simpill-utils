# =============================================================================
# STRING-ONLY ENV SAMPLES
# =============================================================================
# Focused fixture for string parsing tests
# =============================================================================

# Basic strings
STRING_BASIC=hello
STRING_EMPTY=
STRING_WITH_SPACES=hello world
STRING_WITH_TABS=hello	world

# Special characters
STRING_SPECIAL_CHARS=!@#$%^&*()
STRING_URL=https://api.example.com/v1/users?active=true
STRING_EMAIL=user@example.com
STRING_PATH=/usr/local/bin/app

# Quoted values
STRING_SINGLE_QUOTED='single quoted'
STRING_DOUBLE_QUOTED="double quoted"
STRING_NESTED_QUOTES="it's a \"test\""

# JSON and structured data
STRING_JSON={"name":"test","value":123}
STRING_ARRAY=[1,2,3,4,5]
STRING_CSV=one,two,three,four

# Unicode and international
STRING_UNICODE=Привет мир
STRING_EXTENDED_ASCII=Hello World (extended)
STRING_ACCENTS=café résumé naïve

# Edge cases
STRING_EQUALS=key=value
STRING_HASH=before#after
STRING_NEWLINE_ESCAPED=line1\nline2
