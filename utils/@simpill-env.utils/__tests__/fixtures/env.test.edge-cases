# =============================================================================
# EDGE CASE ENV SAMPLES
# =============================================================================
# Focused fixture for edge case and error handling tests
# =============================================================================

# Whitespace handling
EDGE_LEADING_SPACE= value
EDGE_TRAILING_SPACE=value 
EDGE_BOTH_SPACES= value 
EDGE_ONLY_SPACES=   
EDGE_TABS=	tabbed	

# Special characters in values
EDGE_EQUALS_SIGN=key=value=more
EDGE_HASH_CHAR=before#after
EDGE_DOLLAR_SIGN=$HOME/path
EDGE_BACKSLASH=path\\to\\file
EDGE_FORWARD_SLASH=/path/to/file

# Quotes and escaping
EDGE_UNMATCHED_SINGLE='unmatched
EDGE_UNMATCHED_DOUBLE="unmatched
EDGE_ESCAPED_QUOTE=it\'s escaped
EDGE_DOUBLE_ESCAPED=it\"s escaped

# Empty and missing
EDGE_EMPTY_VALUE=
EDGE_NO_VALUE

# Long values
EDGE_LONG_VALUE=abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789

# Multiline (if supported)
EDGE_MULTILINE="line1
line2
line3"

# Variable expansion (dotenvx feature)
EDGE_BASE_URL=https://api.example.com
EDGE_FULL_URL=${EDGE_BASE_URL}/v1/users
