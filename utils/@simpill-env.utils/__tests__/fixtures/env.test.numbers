# =============================================================================
# NUMBER-ONLY ENV SAMPLES
# =============================================================================
# Focused fixture for number parsing tests
# =============================================================================

# Valid integers
NUMBER_POSITIVE=42
NUMBER_ZERO=0
NUMBER_NEGATIVE=-100
NUMBER_LARGE=2147483647
NUMBER_SMALL=-2147483648

# Common use cases
NUMBER_PORT=3000
NUMBER_TIMEOUT_MS=30000
NUMBER_MAX_RETRIES=3
NUMBER_BATCH_SIZE=100
NUMBER_RATE_LIMIT=1000

# Edge cases (parseInt behavior)
NUMBER_LEADING_ZEROS=007
NUMBER_WITH_PLUS=+42
NUMBER_SCIENTIFIC=1e5

# Invalid numbers (should return default)
NUMBER_INVALID_TEXT=not-a-number
NUMBER_INVALID_EMPTY=
NUMBER_INVALID_FLOAT=3.14
NUMBER_INVALID_MIXED=42abc
NUMBER_INVALID_SPECIAL=@#$
NUMBER_INVALID_INFINITY=Infinity
NUMBER_INVALID_NAN=NaN
