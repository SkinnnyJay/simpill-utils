# Invalid booleans (should return default)
BOOL_INVALID_YES=yes
BOOL_INVALID_NO=no
BOOL_INVALID_ON=on
BOOL_INVALID_OFF=off
BOOL_INVALID_Y=y
BOOL_INVALID_N=n
BOOL_INVALID_EMPTY=
BOOL_INVALID_TEXT=maybe
BOOL_INVALID_NUMBER=42
