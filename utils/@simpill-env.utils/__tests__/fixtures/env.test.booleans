# Focused fixture for boolean parsing tests
# =============================================================================

# Valid true values
BOOL_TRUE_LOWER=true
BOOL_TRUE_UPPER=TRUE
BOOL_TRUE_MIXED=True
BOOL_TRUE_CAMEL=TrUe
