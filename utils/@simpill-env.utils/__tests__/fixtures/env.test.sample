# =============================================================================
# ENV SAMPLES - Test Fixtures for @simpill/env.utils
# =============================================================================
# This file contains sample environment variables of each supported type.
# Used by integration tests to validate parsing behavior.
# =============================================================================

# -----------------------------------------------------------------------------
# STRING VALUES
# -----------------------------------------------------------------------------
TEST_STRING_SIMPLE=hello
TEST_STRING_EMPTY=
TEST_STRING_WITH_SPACES=hello world
TEST_STRING_WITH_SPECIAL=hello@world#123!
TEST_STRING_URL=https://example.com/api/v1
TEST_STRING_PATH=/var/log/app.log
TEST_STRING_JSON={"key":"value","nested":{"foo":"bar"}}

# Quoted strings (quotes should be stripped by dotenvx)
TEST_STRING_SINGLE_QUOTED='single quoted value'
TEST_STRING_DOUBLE_QUOTED="double quoted value"
TEST_STRING_QUOTED_WITH_SPACES="value with spaces"

# -----------------------------------------------------------------------------
# NUMBER VALUES
# -----------------------------------------------------------------------------
TEST_NUMBER_INTEGER=42
TEST_NUMBER_ZERO=0
TEST_NUMBER_NEGATIVE=-100
TEST_NUMBER_LARGE=9999999
TEST_NUMBER_PORT=3000
TEST_NUMBER_TIMEOUT=30000

# Invalid numbers (should fall back to default)
TEST_NUMBER_INVALID=not-a-number
TEST_NUMBER_FLOAT=3.14
TEST_NUMBER_MIXED=42abc

# -----------------------------------------------------------------------------
# BOOLEAN VALUES
# -----------------------------------------------------------------------------
# Truthy values
TEST_BOOL_TRUE_LOWER=true
TEST_BOOL_TRUE_UPPER=TRUE
TEST_BOOL_TRUE_MIXED=True
TEST_BOOL_ONE=1

# Falsy values
TEST_BOOL_FALSE_LOWER=false
TEST_BOOL_FALSE_UPPER=FALSE
TEST_BOOL_FALSE_MIXED=False
TEST_BOOL_ZERO=0

# Invalid booleans (should fall back to default)
TEST_BOOL_INVALID=maybe
TEST_BOOL_YES=yes
TEST_BOOL_NO=no

# -----------------------------------------------------------------------------
# NODE_ENV SAMPLES
# -----------------------------------------------------------------------------
# Uncomment one to test environment detection
# NODE_ENV=development
# NODE_ENV=production
# NODE_ENV=test

# -----------------------------------------------------------------------------
# EDGE CASES
# -----------------------------------------------------------------------------
TEST_EDGE_WHITESPACE_BEFORE= leading-space
TEST_EDGE_WHITESPACE_AFTER=trailing-space 
TEST_EDGE_EQUALS_IN_VALUE=key=value=more
TEST_EDGE_UNICODE=héllo wörld 🌍
