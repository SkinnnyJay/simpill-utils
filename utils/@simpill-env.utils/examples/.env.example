# Example environment file for @simpill/env.utils demos
# Copy this to .env.local or .env to test the examples

# =============================================================================
# DOTENVX ENCRYPTION (optional)
# =============================================================================
# Private key for decrypting encrypted .env values
# Generated by: dotenvx encrypt
# Store securely - NEVER commit to version control!
# DOTENV_PRIVATE_KEY=your-private-key-here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_NAME=my-awesome-app
APP_VERSION=1.0.0
NODE_ENV=development

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3000
HOST=localhost
API_URL=https://api.example.com

# =============================================================================
# FEATURE FLAGS (boolean examples)
# =============================================================================
# Accepted truthy values: "true", "1" (case-insensitive)
# Accepted falsy values: "false", "0" (case-insensitive)
FEATURE_DARK_MODE=true
FEATURE_ANALYTICS=1
FEATURE_BETA=false
FEATURE_LEGACY=0

# =============================================================================
# NUMERIC CONFIGURATION
# =============================================================================
MAX_CONNECTIONS=100
TIMEOUT_MS=5000
RETRY_COUNT=3
CACHE_TTL=3600

# =============================================================================
# SECRETS (never commit real values!)
# =============================================================================
# Consider using dotenvx encryption for these:
#   dotenvx set DATABASE_URL "postgresql://..." --encrypt
DATABASE_URL=postgresql://localhost:5432/mydb
API_KEY=your-api-key-here
JWT_SECRET=your-jwt-secret-here

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================
DEBUG_MODE=true
LOG_LEVEL=info
