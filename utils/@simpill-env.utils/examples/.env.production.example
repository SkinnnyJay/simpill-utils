# Production environment overrides
# Demonstrates how later files can override earlier ones with overload: true

NODE_ENV=production

# Production-specific values
PORT=8080
DEBUG_MODE=false
LOG_LEVEL=error

# Feature flags for production
FEATURE_BETA=false
FEATURE_ANALYTICS=true

# Higher limits for production
MAX_CONNECTIONS=1000
TIMEOUT_MS=30000
CACHE_TTL=86400
