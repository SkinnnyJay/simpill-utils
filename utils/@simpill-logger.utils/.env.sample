# @simpill/logger.utils Environment Configuration
# Copy this file to .env and customize as needed
# All variables are optional - defaults are shown in comments

# =============================================================================
# LOG LEVEL
# =============================================================================
# Minimum log level to output
# Values: DEBUG, INFO, WARN, ERROR (case-insensitive)
# Default: DEBUG
LOG_LEVEL=INFO

# =============================================================================
# OUTPUT FORMAT
# =============================================================================
# Log output format
# Values: json, pretty (case-insensitive)
# - json: Structured JSON output (recommended for production)
# - pretty: Human-readable text output (recommended for development)
# Default: pretty
LOG_FORMAT=pretty

# =============================================================================
# TIMESTAMPS
# =============================================================================
# Include timestamps in log output
# Values: true, false, 1, 0, yes, no (case-insensitive)
# Default: true
LOG_TIMESTAMPS=true

# =============================================================================
# COLORS
# =============================================================================
# Enable colored output (only applies when LOG_FORMAT=pretty)
# Values: true, false, 1, 0, yes, no (case-insensitive)
# Default: true
LOG_COLORS=true

# =============================================================================
# HOSTNAME (Optional)
# =============================================================================
# Override hostname in log context
# Useful in containerized environments where os.hostname() may not be meaningful
# Default: undefined (uses system hostname if available)
# HOSTNAME=my-service-pod-xyz
