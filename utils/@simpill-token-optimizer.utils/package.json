{
  "name": "@simpill/token-optimizer.utils",
  "version": "1.0.0",
  "description": "Token optimization utilities: cleaning, strategies, telemetry (Node and Edge).",
  "repository": {
    "type": "git",
    "url": "https://github.com/SkinnnyJay/simpill.git",
    "directory": "utils/@simpill-token-optimizer.utils"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js",
      "require": "./dist/shared/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist coverage .jest-cache node_modules/.cache",
    "build": "tsc",
    "dev": "npm run build",
    "dev:watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "publish": "npm publish",
    "verify": "./scripts/check.sh",
    "prepare": "./scripts/install-hooks.sh",
    "setup:hooks": "./scripts/install-hooks.sh",
    "all": "./scripts/build-all.sh"
  },
  "keywords": [
    "typescript",
    "token",
    "optimization",
    "llm",
    "telemetry"
  ],
  "author": "@SkinnnyJay",
  "license": "ISC",
  "sideEffects": false,
  "dependencies": {
    "fast-xml-parser": "^5.3.5",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.2",
    "papaparse": "^5.5.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "typescript": ">=4.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@faker-js/faker": "^10.3.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/papaparse": "^5.3.15",
    "@types/node": "^25.2.3",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "ts-node": "^10.9.2"
  },
  "bugs": {
    "url": "https://github.com/SkinnnyJay/simpill/issues"
  },
  "homepage": "https://github.com/SkinnnyJay/simpill/tree/main/utils/@simpill-token-optimizer.utils#readme"
}
