{
  "name": "@simpill/nextjs.utils",
  "version": "1.0.0",
  "description": "Next.js App Router helpers: safe server actions, route handlers, request context, middleware.",
  "repository": {
    "type": "git",
    "url": "https://github.com/SkinnnyJay/nextjs.utils.git"
  },
  "bugs": {
    "url": "https://github.com/SkinnnyJay/nextjs.utils/issues"
  },
  "homepage": "https://github.com/SkinnnyJay/nextjs.utils#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js",
      "require": "./dist/shared/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist coverage .jest-cache node_modules/.cache",
    "build": "tsc",
    "dev": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "verify": "./scripts/check.sh"
  },
  "keywords": [
    "simpill",
    "typescript",
    "utilities",
    "type-safe",
    "esm",
    "tree-shakeable",
    "nextjs",
    "react",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "sideEffects": false,
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "jest": "^30.2.0",
    "next": "^16.1.6",
    "react": "^18.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@simpill/errors.utils": "file:../@simpill-errors.utils",
    "@simpill/protocols.utils": "file:../@simpill-protocols.utils",
    "@simpill/request-context.utils": "file:../@simpill-request-context.utils",
    "@simpill/zod.utils": "file:../@simpill-zod.utils",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "typescript": ">=4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "typesVersions": {
    "*": {
      "client": [
        "./dist/client/index.d.ts"
      ],
      "server": [
        "./dist/server/index.d.ts"
      ],
      "shared": [
        "./dist/shared/index.d.ts"
      ]
    }
  }
}
